{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optimizer-fingerprinting.local/schemas/fingerprint.schema.json",
  "title": "Optimizer fingerprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fingerprint_id",
    "run_id",
    "task",
    "model",
    "optimizer",
    "metric_names",
    "snapshots"
  ],
  "properties": {
    "schema": {
      "const": "optimizer_fingerprint"
    },
    "fingerprint_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dataset", "batch_size", "seed", "max_steps", "snapshot_interval", "svd_max_dim"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "dataset": { "type": "string", "minLength": 1 },
        "batch_size": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "snapshot_interval": { "type": "integer", "minimum": 1 },
        "svd_max_dim": { "type": "integer", "minimum": 1 }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "family"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 }
      }
    },
    "metric_names": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "snapshots": {
      "type": "array",
      "items": { "$ref": "#/$defs/snapshot" }
    }
  },
  "$defs": {
    "metric_value": {
      "type": ["number", "null"]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "metrics"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "loss",
            "grad_norm",
            "update_norm",
            "theta_norm",
            "path_length",
            "displacement",
            "directness",
            "update_neg_grad_cos",
            "update_prev_update_cos",
            "update_grad_norm_ratio",
            "update_theta_norm_ratio",
            "cosine_from_initial",
            "cosine_from_previous_snapshot",
            "matrix_update_grad_cos",
            "matrix_update_polar_grad_cos",
            "matrix_update_effective_rank",
            "matrix_update_singular_entropy",
            "matrix_update_nuclear_fro_ratio"
          ],
          "properties": {
            "loss": { "$ref": "#/$defs/metric_value" },
            "grad_norm": { "$ref": "#/$defs/metric_value" },
            "update_norm": { "$ref": "#/$defs/metric_value" },
            "theta_norm": { "$ref": "#/$defs/metric_value" },
            "path_length": { "$ref": "#/$defs/metric_value" },
            "displacement": { "$ref": "#/$defs/metric_value" },
            "directness": { "$ref": "#/$defs/metric_value" },
            "update_neg_grad_cos": { "$ref": "#/$defs/metric_value" },
            "update_prev_update_cos": { "$ref": "#/$defs/metric_value" },
            "update_grad_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "update_theta_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "cosine_from_initial": { "$ref": "#/$defs/metric_value" },
            "cosine_from_previous_snapshot": { "$ref": "#/$defs/metric_value" },
            "matrix_update_grad_cos": { "$ref": "#/$defs/metric_value" },
            "matrix_update_polar_grad_cos": { "$ref": "#/$defs/metric_value" },
            "matrix_update_effective_rank": { "$ref": "#/$defs/metric_value" },
            "matrix_update_singular_entropy": { "$ref": "#/$defs/metric_value" },
            "matrix_update_nuclear_fro_ratio": { "$ref": "#/$defs/metric_value" }
          }
        }
      }
    }
  }
}
