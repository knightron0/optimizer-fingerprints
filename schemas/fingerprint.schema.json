{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optimizer-fingerprinting.local/schemas/fingerprint.schema.json",
  "title": "Optimizer fingerprint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "fingerprint_id",
    "run_id",
    "task",
    "model",
    "optimizer",
    "metric_names",
    "parameter_metric_names",
    "snapshots"
  ],
  "properties": {
    "schema": {
      "const": "optimizer_fingerprint"
    },
    "fingerprint_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "dataset", "batch_size", "seed", "max_steps", "snapshot_interval", "svd_max_dim"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "dataset": { "type": "string", "minLength": 1 },
        "batch_size": { "type": "integer", "minimum": 1 },
        "seed": { "type": "integer" },
        "max_steps": { "type": "integer", "minimum": 1 },
        "snapshot_interval": { "type": "integer", "minimum": 1 },
        "svd_max_dim": { "type": "integer", "minimum": 1 }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "family"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 }
      }
    },
    "metric_names": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "parameter_metric_names": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "snapshots": {
      "type": "array",
      "items": { "$ref": "#/$defs/snapshot" }
    }
  },
  "$defs": {
    "metric_value": {
      "type": ["number", "null"]
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "metrics", "parameters"],
      "properties": {
        "step": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "loss",
            "grad_norm",
            "update_norm",
            "theta_norm",
            "path_length",
            "displacement",
            "directness",
            "update_neg_grad_cos",
            "update_prev_update_cos",
            "update_grad_norm_ratio",
            "update_theta_norm_ratio",
            "theta_initial_cos",
            "theta_prev_snapshot_cos"
          ],
          "properties": {
            "loss": { "$ref": "#/$defs/metric_value" },
            "grad_norm": { "$ref": "#/$defs/metric_value" },
            "update_norm": { "$ref": "#/$defs/metric_value" },
            "theta_norm": { "$ref": "#/$defs/metric_value" },
            "path_length": { "$ref": "#/$defs/metric_value" },
            "displacement": { "$ref": "#/$defs/metric_value" },
            "directness": { "$ref": "#/$defs/metric_value" },
            "update_neg_grad_cos": { "$ref": "#/$defs/metric_value" },
            "update_prev_update_cos": { "$ref": "#/$defs/metric_value" },
            "update_grad_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "update_theta_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "theta_initial_cos": { "$ref": "#/$defs/metric_value" },
            "theta_prev_snapshot_cos": { "$ref": "#/$defs/metric_value" }
          }
        },
        "parameters": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameter_snapshot" }
        }
      }
    },
    "parameter_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "shape", "ndim", "numel", "metrics"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "shape": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "ndim": { "type": "integer", "minimum": 0 },
        "numel": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "grad_norm",
            "update_norm",
            "theta_norm",
            "path_length",
            "displacement",
            "directness",
            "update_neg_grad_cos",
            "update_prev_update_cos",
            "update_grad_norm_ratio",
            "update_theta_norm_ratio",
            "theta_initial_cos",
            "theta_prev_snapshot_cos",
            "update_stable_rank",
            "update_spectral_concentration",
            "update_singular_value_spread",
            "update_orthogonality_error",
            "update_row_norm_cv",
            "update_col_norm_cv",
            "update_rms",
            "update_l1_l2_ratio",
            "update_linf_l2_ratio",
            "update_zero_fraction",
            "update_kurtosis",
            "update_abs_grad_abs_corr",
            "update_sign_grad_agreement"
          ],
          "properties": {
            "grad_norm": { "$ref": "#/$defs/metric_value" },
            "update_norm": { "$ref": "#/$defs/metric_value" },
            "theta_norm": { "$ref": "#/$defs/metric_value" },
            "path_length": { "$ref": "#/$defs/metric_value" },
            "displacement": { "$ref": "#/$defs/metric_value" },
            "directness": { "$ref": "#/$defs/metric_value" },
            "update_neg_grad_cos": { "$ref": "#/$defs/metric_value" },
            "update_prev_update_cos": { "$ref": "#/$defs/metric_value" },
            "update_grad_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "update_theta_norm_ratio": { "$ref": "#/$defs/metric_value" },
            "theta_initial_cos": { "$ref": "#/$defs/metric_value" },
            "theta_prev_snapshot_cos": { "$ref": "#/$defs/metric_value" },
            "update_stable_rank": { "$ref": "#/$defs/metric_value" },
            "update_spectral_concentration": { "$ref": "#/$defs/metric_value" },
            "update_singular_value_spread": { "$ref": "#/$defs/metric_value" },
            "update_orthogonality_error": { "$ref": "#/$defs/metric_value" },
            "update_row_norm_cv": { "$ref": "#/$defs/metric_value" },
            "update_col_norm_cv": { "$ref": "#/$defs/metric_value" },
            "update_rms": { "$ref": "#/$defs/metric_value" },
            "update_l1_l2_ratio": { "$ref": "#/$defs/metric_value" },
            "update_linf_l2_ratio": { "$ref": "#/$defs/metric_value" },
            "update_zero_fraction": { "$ref": "#/$defs/metric_value" },
            "update_kurtosis": { "$ref": "#/$defs/metric_value" },
            "update_abs_grad_abs_corr": { "$ref": "#/$defs/metric_value" },
            "update_sign_grad_agreement": { "$ref": "#/$defs/metric_value" }
          }
        }
      }
    }
  }
}
