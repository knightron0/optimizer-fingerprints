---
import Layout from '../../layouts/Layout.astro';
import { fingerprintSnapshotCount, fingerprintTaskId, loadFingerprints } from '../../lib/data';

const loadedFingerprints = loadFingerprints();
const fingerprints = loadedFingerprints.map((entry) => ({
	entry: {
		fingerprint_id: entry.fingerprint_id,
		optimizer: entry.optimizer,
		optimizer_family: entry.optimizer_family,
		seed: entry.seed,
		task_id: fingerprintTaskId(entry),
		snapshot_count: fingerprintSnapshotCount(entry),
		path: entry.path,
	},
	full: entry.full,
}));

const metricSections = [
	{ id: 'training', title: 'Training', metrics: ['loss', 'grad_norm', 'update_norm', 'theta_norm'] },
	{
		id: 'trajectory',
		title: 'Trajectory',
		metrics: ['path_length', 'displacement', 'directness', 'theta_initial_cos', 'theta_prev_snapshot_cos'],
	},
	{
		id: 'direction',
		title: 'Direction / scale',
		metrics: ['update_neg_grad_cos', 'update_prev_update_cos', 'update_grad_norm_ratio', 'update_theta_norm_ratio'],
	},
	{
		id: 'matrix',
		title: 'Matrix',
		metrics: [
			'update_stable_rank',
			'update_spectral_concentration',
			'update_singular_value_spread',
			'update_orthogonality_error',
			'update_row_norm_cv',
			'update_col_norm_cv',
		],
	},
	{
		id: 'elementwise',
		title: 'Elementwise',
		metrics: [
			'update_rms',
			'update_l1_l2_ratio',
			'update_linf_l2_ratio',
			'update_zero_fraction',
			'update_kurtosis',
			'update_abs_grad_abs_corr',
			'update_sign_grad_agreement',
		],
	},
];
---

<Layout title="Fingerprint">
	<section class="fingerprint-shell" aria-label="Fingerprint workspace" data-fingerprint-root>
		{
			fingerprints.length === 0 ? (
				<div class="empty">
					No current-schema fingerprints are available. Regenerate fingerprints with the current
					<code>optimizer_fingerprint</code> schema and rebuild <code>web/public/fingerprints.json</code>.
				</div>
			) : (
				<>
					<div class="pane-frame">
						<div class="pane-inner">
							<div class="fingerprint-toolbar">
								<div class="field">
									<label for="fingerprint-select">Fingerprint</label>
									<select id="fingerprint-select" data-fingerprint-select>
										{fingerprints.map(({ full }, index) => (
											<option value={String(index)}>
												{full.optimizer.name} / {full.task.id} / seed {full.task.seed} / {full.snapshots.length} snapshots
											</option>
										))}
									</select>
								</div>
							</div>
						</div>
					</div>

					{metricSections.map((section) => (
						<div class="pane-frame metric-section-frame">
							<div class="pane-inner">
								<details class="fingerprint-section metric-details" open>
									<summary class="section-title">{section.title} <span>snapshot traces</span></summary>
									<div class="chart-grid" data-chart-section={section.id}>
										{section.metrics.map((metric) => (
											<article class="metric-chart" data-metric={metric}>
												<header>
													<h3>{metric.replaceAll('_', ' ')}</h3>
													<span class="num" data-latest-value>n/a</span>
													</header>
													<div class="mini-trace">
													<svg viewBox="0 0 360 160" role="img">
														<g class="chart-grid-lines" aria-hidden="true">
															<line x1="86" y1="16" x2="86" y2="132"></line>
															<line x1="138" y1="16" x2="138" y2="132"></line>
															<line x1="190" y1="16" x2="190" y2="132"></line>
															<line x1="242" y1="16" x2="242" y2="132"></line>
															<line x1="294" y1="16" x2="294" y2="132"></line>
															<line x1="34" y1="45" x2="346" y2="45"></line>
															<line x1="34" y1="74" x2="346" y2="74"></line>
															<line x1="34" y1="103" x2="346" y2="103"></line>
														</g>
														<line x1="34" y1="16" x2="34" y2="132" class="chart-axis"></line>
														<line x1="34" y1="132" x2="346" y2="132" class="chart-axis"></line>
														<path class="chart-line" data-chart-path></path>
														<g data-chart-points></g>
														<text x="34" y="150" class="chart-label" data-min-step></text>
														<text x="346" y="150" text-anchor="end" class="chart-label" data-max-step></text>
														<text x="6" y="20" class="chart-label" data-max-value></text>
														<text x="6" y="135" class="chart-label" data-min-value></text>
													</svg>
												</div>
											</article>
										))}
									</div>
								</details>
							</div>
						</div>
					))}

					<div class="pane-frame">
						<div class="pane-inner">
							<section class="fingerprint-section">
								<h2 class="section-title">Snapshots <span>schema metric order</span></h2>
								<div class="table-wrap">
									<table class="snapshot-table">
										<thead data-snapshot-head></thead>
										<tbody data-snapshot-body></tbody>
									</table>
								</div>
							</section>
						</div>
					</div>

					<div class="pane-frame">
						<div class="pane-inner">
							<details>
								<summary>Raw fingerprint JSON</summary>
								<pre data-raw-json></pre>
							</details>
						</div>
					</div>
				</>
			)
		}

	</section>
</Layout>

<style is:global>
	.fingerprint-shell {
		box-sizing: border-box;
		display: grid;
		gap: 16px;
		width: 100%;
		max-width: 100%;
		min-width: 0;
		padding: 10px 28px 0;
	}

	.fingerprint-shell *,
	.fingerprint-shell *::before,
	.fingerprint-shell *::after {
		box-sizing: border-box;
	}

	.fingerprint-shell .pane-frame,
	.fingerprint-shell .pane-inner,
	.fingerprint-section,
	.fingerprint-shell .table-wrap {
		width: 100%;
		max-width: 100%;
		min-width: 0;
	}

	.fingerprint-shell .pane-frame {
		overflow: hidden;
	}

	.fingerprint-shell .empty,
	.fingerprint-shell code,
	.fingerprint-shell pre {
		overflow-wrap: anywhere;
	}

	.fingerprint-toolbar {
		display: block;
	}

	.fingerprint-toolbar > .field {
		min-width: 0;
	}

	.fingerprint-section {
		position: relative;
	}

	.metric-details {
		border-top: 0;
		padding: 0;
		font-family: inherit;
	}

	.metric-details > summary.section-title {
		cursor: pointer;
		list-style: none;
		margin-bottom: 14px;
	}

	.metric-details > summary.section-title::-webkit-details-marker {
		display: none;
	}

	.metric-details > summary.section-title::before {
		content: 'v';
		color: var(--muted);
		font-size: 12px;
	}

	.metric-details:not([open]) > summary.section-title {
		margin-bottom: 0;
	}

	.metric-details:not([open]) > summary.section-title::before {
		content: '>';
	}

	.chart-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
	}

	.metric-chart {
		min-width: 0;
		border: 1px solid var(--line);
		background: var(--paper);
	}

	.metric-chart header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 12px;
		padding: 10px 12px;
		border-bottom: 1px solid var(--line);
		font-family: var(--sans);
	}

	.metric-chart h3 {
		margin: 0;
		overflow: hidden;
		color: var(--ink);
		font-size: 12px;
		font-weight: 600;
		text-overflow: ellipsis;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		white-space: nowrap;
	}

	.metric-chart header span {
		flex: 0 0 auto;
		color: var(--muted);
		font-size: 12px;
	}

	.mini-trace {
		position: relative;
		min-height: 190px;
		background: var(--paper);
	}

	.mini-trace svg {
		display: block;
		width: 100%;
		min-height: 190px;
	}

	.chart-axis {
		stroke: var(--line-strong);
		stroke-width: 1;
	}

	.chart-grid-lines line {
		stroke: var(--line);
		stroke-width: 1;
	}

	.chart-line {
		fill: none;
		stroke: var(--accent);
		stroke-width: 2;
	}

	.chart-point {
		fill: var(--accent);
	}

	.chart-label {
		fill: var(--muted);
		font-family: var(--mono);
		font-size: 9px;
	}

	.snapshot-table {
		min-width: 980px;
	}

	.unsupported-table {
		min-width: 760px;
		table-layout: fixed;
	}

	.unsupported-table th:nth-child(1),
	.unsupported-table th:nth-child(6) {
		width: 30%;
	}

	.wrap-cell {
		white-space: normal;
		overflow-wrap: anywhere;
	}

	@media (max-width: 760px) {
		.fingerprint-shell {
			padding-inline: 16px;
		}

		.chart-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<script define:vars={{ fingerprints }}>
	const root = document.querySelector('[data-fingerprint-root]');
	const fingerprintSelect = root?.querySelector('[data-fingerprint-select]');

	const format = (value) => {
		if (!Number.isFinite(value)) return 'n/a';
		const abs = Math.abs(value);
		if (abs !== 0 && (abs < 0.01 || abs >= 10000)) return value.toExponential(2);
		return value.toLocaleString('en-US', { maximumFractionDigits: 6 });
	};
	const formatFigure = (value) => {
		if (!Number.isFinite(value)) return 'n/a';
		const abs = Math.abs(value);
		if (abs !== 0 && (abs < 0.01 || abs >= 1000)) return value.toExponential(2);
		return value.toLocaleString('en-US', {
			maximumSignificantDigits: 4,
			useGrouping: false,
		});
	};

	const metricLabel = (name) => name.replaceAll('_', ' ');
	function selectedFingerprint() {
		return fingerprints[Number(fingerprintSelect?.value ?? 0)];
	}

	function setText(selector, value) {
		const element = root?.querySelector(selector);
		if (element) element.textContent = value;
	}

	function renderAllCharts(fingerprint) {
		for (const chart of root.querySelectorAll('[data-metric]')) {
			renderMetricChart(chart, fingerprint);
		}
	}

	function renderMetricChart(chart, fingerprint) {
		const metric = chart.dataset.metric;
		const path = chart.querySelector('[data-chart-path]');
		const points = chart.querySelector('[data-chart-points]');
		const latest = chart.querySelector('[data-latest-value]');
		const values = fingerprint.snapshots
			.map((snapshot) => ({ step: snapshot.step, value: snapshot.metrics[metric] }))
			.filter((point) => Number.isFinite(point.value));

		latest.textContent = values.length ? formatFigure(values.at(-1).value) : 'n/a';
		if (!path || !points || values.length === 0) {
			if (path) path.setAttribute('d', '');
			points?.replaceChildren();
			return;
		}

		const minStep = Math.min(...values.map((point) => point.step));
		const maxStep = Math.max(...values.map((point) => point.step));
		const minValue = Math.min(...values.map((point) => point.value));
		const maxValue = Math.max(...values.map((point) => point.value));
		const stepSpan = Math.max(maxStep - minStep, 1);
		const valueSpan = Math.max(maxValue - minValue, 1e-20);
		const x = (step) => 34 + ((step - minStep) / stepSpan) * 312;
		const y = (value) => 132 - ((value - minValue) / valueSpan) * 116;
		path.setAttribute(
			'd',
			values.map((point, index) => `${index === 0 ? 'M' : 'L'} ${x(point.step).toFixed(2)} ${y(point.value).toFixed(2)}`).join(' '),
		);
		points.replaceChildren(
			...values.map((point) => {
				const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
				circle.setAttribute('class', 'chart-point');
				circle.setAttribute('cx', x(point.step).toFixed(2));
				circle.setAttribute('cy', y(point.value).toFixed(2));
				circle.setAttribute('r', '2.5');
				return circle;
			}),
		);
		chart.querySelector('[data-min-step]').textContent = String(minStep);
		chart.querySelector('[data-max-step]').textContent = String(maxStep);
		chart.querySelector('[data-min-value]').textContent = formatFigure(minValue);
		chart.querySelector('[data-max-value]').textContent = formatFigure(maxValue);
		chart.querySelector('svg')?.setAttribute('aria-label', `${metricLabel(metric)} over snapshot steps`);
	}

	function renderSnapshots(fingerprint) {
		const head = root.querySelector('[data-snapshot-head]');
		const body = root.querySelector('[data-snapshot-body]');
		const headerRow = document.createElement('tr');
		const stepHead = document.createElement('th');
		stepHead.textContent = 'Step';
		stepHead.className = 'num';
		headerRow.append(stepHead);
		for (const metric of fingerprint.metric_names) {
			const th = document.createElement('th');
			th.textContent = metricLabel(metric);
			th.className = 'num';
			headerRow.append(th);
		}
		head?.replaceChildren(headerRow);
		body?.replaceChildren(
			...fingerprint.snapshots.map((snapshot) => {
				const row = document.createElement('tr');
				const step = document.createElement('td');
				step.textContent = String(snapshot.step);
				step.className = 'num';
				row.append(step);
				for (const metric of fingerprint.metric_names) {
					const cell = document.createElement('td');
					cell.textContent = format(snapshot.metrics[metric]);
					cell.className = 'num';
					row.append(cell);
				}
				return row;
			}),
		);
	}

	function render() {
		const selected = selectedFingerprint();
		if (!selected) return;
		const { full } = selected;
		setText('[data-raw-json]', JSON.stringify(full, null, 2));
		renderAllCharts(full);
		renderSnapshots(full);
	}

	fingerprintSelect?.addEventListener('change', render);
	render();
</script>
