---
import Layout from '../../layouts/Layout.astro';
import { loadRuns } from '../../lib/data';

const runs = loadRuns().map((entry) => ({ full: entry.full }));
---

<Layout title="Trace">
	<section class="fingerprint-shell" data-fingerprint-root>
		{
			runs.length === 0 ? (
				<div class="empty">No NanoGPT traces are available.</div>
			) : (
				<>
					<header class="fingerprint-topbar">
						<div class="field optimizer-picker">
							<label class="sr-only" for="fingerprint-select">Trace</label>
							<button type="button" class="optimizer-trigger" data-optimizer-trigger aria-expanded="false" aria-haspopup="listbox"></button>
							<select class="sr-only" id="fingerprint-select" data-fingerprint-select tabindex="-1">
								{runs.map(({ full }, index) => (
									<option value={String(index)}>
										{full.optimizer.name}
									</option>
								))}
							</select>
							<div class="optimizer-menu" data-optimizer-menu role="listbox" aria-hidden="true"></div>
						</div>
					</header>

					<div class="overview-card" data-overview-card></div>
					<div class="metric-panes" data-metric-sections></div>

					<div class="custom-modal" data-custom-modal aria-hidden="true">
						<div class="custom-dialog">
							<header>
								<h2>Custom Parameters</h2>
								<button type="button" data-custom-close aria-label="Close custom parameter picker">x</button>
							</header>
							<div class="custom-tools">
								<div class="field">
									<label for="custom-filter">Filter</label>
										<input id="custom-filter" type="search" placeholder="attn, mlp, weight..." data-custom-filter />
								</div>
								<div class="custom-actions">
									<button type="button" data-custom-select-visible>Select visible</button>
									<button type="button" data-custom-clear>Clear</button>
									<button type="button" data-custom-apply>Apply</button>
								</div>
							</div>
							<div class="custom-count" data-custom-count></div>
							<div class="custom-list" data-custom-list></div>
						</div>
					</div>
				</>
			)
		}
	</section>
</Layout>

<style is:global>
	.fingerprint-shell {
		box-sizing: border-box;
		padding: 10px 28px 0;
	}

	.fingerprint-shell *,
	.fingerprint-shell *::before,
	.fingerprint-shell *::after {
		box-sizing: border-box;
	}

	.fingerprint-shell .sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	.fingerprint-topbar {
		display: flex;
		gap: 12px;
		align-items: center;
		justify-content: center;
		margin-bottom: 18px;
	}

	.fingerprint-topbar > .field {
		flex: 0 1 480px;
		min-width: 220px;
	}

	.optimizer-picker {
		position: relative;
	}

	.fingerprint-shell select {
		appearance: none;
		min-height: 34px;
		border: 1px solid var(--line);
		background:
			linear-gradient(45deg, transparent 50%, var(--muted) 50%) calc(100% - 15px) 14px / 5px 5px no-repeat,
			linear-gradient(135deg, var(--muted) 50%, transparent 50%) calc(100% - 10px) 14px / 5px 5px no-repeat,
			var(--paper);
		padding: 6px 28px 6px 9px;
		color: var(--ink);
		font-size: 12px;
		line-height: 1.2;
	}

	.fingerprint-shell select:hover {
		border-color: var(--line-strong);
	}

	.fingerprint-shell select:focus {
		border-color: var(--ink);
		outline: 0;
	}

	.optimizer-trigger {
		display: block;
		width: 100%;
		min-height: 44px;
		border: 0;
		background: transparent;
		color: var(--ink);
		padding: 2px 32px;
		font-family: var(--sans);
		font-size: 28px;
		font-weight: 650;
		letter-spacing: 0;
		line-height: 1.1;
		text-align: center;
		cursor: pointer;
	}

	.optimizer-trigger::after {
		display: inline-block;
		width: 7px;
		height: 7px;
		border-right: 1.5px solid var(--muted);
		border-bottom: 1.5px solid var(--muted);
		margin-left: 12px;
		content: '';
		transform: translateY(-4px) rotate(45deg);
	}

	.optimizer-trigger:hover,
	.optimizer-trigger:focus {
		color: var(--accent);
		outline: 0;
	}

	.optimizer-menu {
		position: absolute;
		top: calc(100% + 8px);
		right: 0;
		z-index: 20;
		display: none;
		width: min(260px, calc(100vw - 56px));
		max-height: 360px;
		overflow: auto;
		border: 1px solid var(--line-strong);
		background: var(--paper);
		box-shadow: 0 12px 28px rgb(31 27 22 / 0.12);
		font-family: var(--sans);
	}

	.optimizer-menu[aria-hidden='false'] {
		display: block;
	}

	.optimizer-option {
		display: block;
		width: 100%;
		border: 0;
		border-bottom: 1px solid var(--line);
		background: transparent;
		padding: 8px 10px;
		color: var(--ink);
		font-size: 12px;
		text-align: left;
		cursor: pointer;
	}

	.optimizer-option:hover,
	.optimizer-option[aria-selected='true'] {
		background: var(--accent-soft);
	}

	.relative-pane {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.selector-bar {
		display: flex;
		gap: 14px;
		align-items: center;
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
		padding: 10px 12px;
	}

	.metric-summary {
		display: flex;
		gap: 12px;
		align-items: center;
		justify-content: space-between;
		padding: 10px 12px;
	}

	.metric-summary-text {
		display: flex;
		gap: 8px;
		align-items: baseline;
		min-width: 0;
	}

	.metric-count {
		color: var(--muted);
		font-family: var(--sans);
		font-size: 11px;
		white-space: nowrap;
	}

	.selector-title {
		margin: 0;
		color: var(--ink);
		font-family: var(--sans);
		font-size: 16px;
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1.25;
		white-space: nowrap;
	}

	.selector-controls {
		display: flex;
		gap: 10px;
		align-items: center;
		justify-content: flex-end;
		width: 100%;
		min-width: 0;
	}

	.selector-bar .field {
		width: min(300px, 32vw);
		min-width: 220px;
	}

	.selector-bar button,
	.metric-summary button,
	.scale-toggle button,
	.custom-dialog button {
		min-height: 34px;
		border: 1px solid var(--line-strong);
		background: var(--paper);
		color: var(--ink);
		padding: 6px 9px;
		font-family: var(--sans);
		font-size: 12px;
		cursor: pointer;
		white-space: nowrap;
	}

	.scale-toggle button[aria-pressed='true'] {
		background: var(--accent-soft);
		font-weight: 600;
	}

	.set-summary,
	.chart-note,
	.custom-count {
		color: var(--muted);
		font-family: var(--sans);
		font-size: 12px;
	}

	.set-summary {
		white-space: nowrap;
	}

	.overview-card {
		border: 1px solid var(--line);
		background: var(--paper);
		font-family: var(--sans);
	}

	.overview-card > header {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
		padding: 10px 12px;
	}

	.overview-card h2 {
		margin: 0;
		color: var(--ink);
		font-size: 16px;
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1.25;
	}

	.overview-card .field {
		flex: 0 0 min(260px, 36vw);
		min-width: 200px;
	}

	.overview-note {
		margin-top: 3px;
		color: var(--muted);
		font-size: 11px;
	}

	.overview-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(180px, 1fr));
	}

	.overview-metric {
		min-width: 0;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 12px;
	}

	.overview-metric:nth-child(3n) {
		border-right: 0;
	}

	.overview-metric:nth-last-child(-n + 3) {
		border-bottom: 0;
	}

	.overview-metric-top {
		min-height: 34px;
	}

	.overview-label {
		color: var(--ink);
		font-size: 12px;
		font-weight: 600;
		line-height: 1.25;
	}

	.overview-description {
		margin-top: 4px;
		color: var(--muted);
		font-size: 11px;
		line-height: 1.35;
	}

	.overview-direction {
		margin-top: 3px;
		color: color-mix(in srgb, var(--muted) 82%, var(--ink) 18%);
		font-size: 11px;
		line-height: 1.3;
	}

	.overview-value {
		margin-top: 8px;
		font-family: var(--mono);
		font-size: 18px;
		line-height: 1.1;
		overflow-wrap: anywhere;
	}

	.overview-percentile {
		display: flex;
		gap: 10px;
		align-items: center;
		justify-content: space-between;
		margin-top: 6px;
		color: var(--muted);
		font-size: 11px;
	}

	.overview-swatch {
		position: relative;
		width: 100%;
		height: 8px;
		background: color-mix(in srgb, var(--paper) 82%, var(--line) 18%);
	}

	.overview-swatch::after {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		width: var(--percentile-width, 0%);
		background: var(--percentile-color, #bfb4a4);
		content: '';
	}

	.overview-rank {
		flex: 0 0 auto;
		font-family: var(--mono);
		color: var(--muted);
	}

	.metric-panes {
		display: grid;
		gap: 16px;
		margin-top: 16px;
	}

	.chart-stack {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.metric-section {
		border: 1px solid var(--line);
		background: var(--paper);
		font-family: var(--sans);
	}

	.metric-section.is-collapsed .selector-bar,
	.metric-section.is-collapsed .chart-stack {
		display: none;
	}

	.chart-card {
		min-width: 0;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		background: var(--paper);
	}

	.chart-card:nth-child(2n) {
		border-right: 0;
	}

	.chart-card:last-child,
	.chart-card:nth-last-child(2):nth-child(odd) {
		border-bottom: 0;
	}

	.chart-card > header {
		display: flex;
		gap: 12px;
		align-items: flex-start;
		justify-content: space-between;
		border-bottom: 1px solid var(--line);
		min-height: 66px;
		padding: 10px 12px 8px;
		font-family: var(--sans);
	}

	.chart-card > header > div:first-child {
		flex: 1 1 auto;
		min-width: 0;
	}

	.chart-card h3 {
		margin: 0;
		color: var(--ink);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0;
		line-height: 1.25;
	}

	.chart-subtitle {
		margin-top: 4px;
		color: var(--muted);
		font-size: 11px;
		line-height: 1.3;
		overflow-wrap: anywhere;
	}

	.chart-note:not(:empty) {
		border-top: 1px solid var(--line);
		padding: 8px 12px;
		font-size: 11px;
	}

	.scale-toggle {
		display: inline-flex;
		gap: 4px;
	}

	.main-chart {
		height: 210px;
		min-height: 210px;
		background: color-mix(in srgb, var(--paper) 94%, white 6%);
	}

	.main-chart > div {
		width: 100%;
		height: 100%;
	}

	.custom-modal {
		position: fixed;
		inset: 0;
		z-index: 30;
		display: none;
		background: rgb(31 27 22 / 0.25);
	}

	.custom-modal[aria-hidden='false'] {
		display: block;
	}

	.custom-dialog {
		position: absolute;
		top: 40px;
		left: 50%;
		width: min(720px, calc(100vw - 32px));
		max-height: calc(100vh - 80px);
		overflow: auto;
		transform: translateX(-50%);
		border: 1px solid var(--line-strong);
		background: var(--paper);
		padding: 16px;
	}

	.custom-dialog > header {
		display: flex;
		justify-content: space-between;
		gap: 16px;
		border-bottom: 1px solid var(--line);
		padding-bottom: 10px;
	}

	.custom-dialog h2 {
		margin: 0;
		font-family: var(--sans);
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.custom-tools {
		display: flex;
		gap: 12px;
		align-items: flex-end;
		margin-top: 12px;
	}

	.custom-tools .field {
		flex: 1 1 220px;
		min-width: 220px;
	}

	.custom-actions {
		display: flex;
		gap: 8px;
	}

	.custom-list {
		display: flex;
		flex-wrap: wrap;
		max-height: 460px;
		overflow: auto;
		border: 1px solid var(--line);
		margin-top: 10px;
		font-family: var(--sans);
		font-size: 12px;
	}

	.custom-option {
		display: flex;
		flex: 1 1 50%;
		gap: 7px;
		align-items: flex-start;
		min-width: min(320px, 100%);
		border-bottom: 1px solid var(--line);
		padding: 7px;
		cursor: pointer;
	}

	.custom-option input {
		flex: 0 0 auto;
	}

	.custom-option span {
		overflow-wrap: anywhere;
		font-family: var(--mono);
		line-height: 1.3;
	}

	@media (max-width: 760px) {
		.fingerprint-topbar,
		.selector-bar,
		.metric-summary,
		.metric-summary-text,
		.custom-tools {
			align-items: stretch;
			flex-direction: column;
		}

		.fingerprint-topbar > .field,
		.selector-bar .field,
		.chart-card,
		.custom-option {
			width: 100%;
			min-width: 0;
		}

		.optimizer-trigger {
			min-height: 40px;
			padding-right: 24px;
			padding-left: 24px;
			font-size: 30px;
		}

		.optimizer-menu {
			right: 50%;
			transform: translateX(50%);
		}

		.chart-stack {
			grid-template-columns: 1fr;
		}

		.chart-card,
		.chart-card:nth-child(2n),
		.chart-card:nth-last-child(2):nth-child(odd) {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}

		.chart-card:last-child {
			border-bottom: 0;
		}

		.overview-grid {
			grid-template-columns: 1fr;
		}

		.overview-card > header {
			align-items: stretch;
			flex-direction: column;
		}

		.overview-card .field {
			width: 100%;
			min-width: 0;
		}

		.overview-metric,
		.overview-metric:nth-child(3n),
		.overview-metric:nth-last-child(-n + 3) {
			border-bottom: 1px solid var(--line);
		}

		.overview-metric:last-child {
			border-bottom: 0;
		}

		.selector-title {
			padding-bottom: 0;
		}

		.selector-controls {
			align-items: stretch;
			flex-wrap: wrap;
			justify-content: flex-start;
		}
	}
</style>

<script id="fingerprint-data" type="application/json" set:html={JSON.stringify(runs)}></script>

<script>
	import { CustomChart, LineChart } from 'echarts/charts';
	import { GridComponent, TooltipComponent } from 'echarts/components';
	import * as echarts from 'echarts/core';
	import { SVGRenderer } from 'echarts/renderers';

	echarts.use([LineChart, CustomChart, GridComponent, TooltipComponent, SVGRenderer]);

	const fingerprints = JSON.parse(document.getElementById('fingerprint-data').textContent);
	const root = document.querySelector('[data-fingerprint-root]');
	const fingerprintSelect = root?.querySelector('[data-fingerprint-select]');
	const optimizerTrigger = root?.querySelector('[data-optimizer-trigger]');
	const optimizerMenu = root?.querySelector('[data-optimizer-menu]');
	const customModal = root?.querySelector('[data-custom-modal]');
	const customClose = root?.querySelector('[data-custom-close]');
	const customFilter = root?.querySelector('[data-custom-filter]');
	const customList = root?.querySelector('[data-custom-list]');
	const customSelectVisible = root?.querySelector('[data-custom-select-visible]');
	const customClear = root?.querySelector('[data-custom-clear]');
	const customApply = root?.querySelector('[data-custom-apply]');
	const customNames = new Set();
	const ratioScales = {
		grad_norm: 'log',
		update_norm: 'log',
		theta_norm: 'log',
		update_theta_norm_ratio: 'log',
	};
	let selectedParameterSet = 'matrix_parameters';
	let overviewParameterSet = 'all_parameters';
	const chartInstances = new Map();
	const openMetricGroups = new Set();
	const parameterSetOptions = [
		['all_parameters', 'all parameters'],
		['matrix_parameters', 'matrix parameters'],
		['vector_parameters', 'vector parameters'],
		['embeddings', 'embeddings'],
		['attention', 'attention'],
		['attention_qkv', 'attention q/k/v'],
		['attention_proj', 'attention proj'],
		['mlp', 'mlp'],
		['norms', 'norms'],
		['output_head', 'output/head'],
		['optimizer_0', 'optimizer 0'],
		['optimizer_1', 'optimizer 1'],
	];
	const chartParameterSetOptions = parameterSetOptions.filter(([value]) => value !== 'all_parameters').concat([['custom', 'custom']]);
	const overviewMetrics = [
		{
			label: 'Gradient Alignment',
			metric: 'update_neg_grad_cos',
			family: 'direction',
			description: 'Updates follow negative gradient.',
			lowMeans: 'wandering',
			higherMeans: 'more aligned',
		},
		{
			label: 'Update Persistence',
			metric: 'update_prev_update_cos',
			family: 'direction',
			description: 'Updates keep direction over time.',
			lowMeans: 'changes direction',
			higherMeans: 'persistent updates',
		},
		{
			label: 'Gradient Norm',
			metric: 'grad_norm',
			family: 'scale',
			scale: 'log',
			description: 'Per-parameter gradient magnitude.',
			lowMeans: 'smaller gradients',
			higherMeans: 'larger gradients',
		},
		{
			label: 'Update Norm',
			metric: 'update_norm',
			family: 'scale',
			scale: 'log',
			description: 'Per-parameter update magnitude.',
			lowMeans: 'smaller updates',
			higherMeans: 'larger updates',
		},
		{
			label: 'Relative Step Size',
			metric: 'update_theta_norm_ratio',
			family: 'scale',
			scale: 'log',
			description: 'Update size per weight size.',
			lowMeans: 'small step',
			higherMeans: 'larger steps',
		},
		{
			label: 'Effective LR Spread',
			metric: 'update_effective_lr_log_std',
			family: 'elementwise',
			description: 'Entrywise effective learning rate variability.',
			lowMeans: 'uniform',
			higherMeans: 'more varied',
		},
		{
			label: 'RMS Suppression',
			metric: 'update_grad_rms_suppression_corr',
			family: 'elementwise',
			description: 'Gradient RMS history versus effective LR.',
			lowMeans: 'suppressed high RMS',
			higherMeans: 'favored high RMS',
		},
		{
			label: 'Coverage',
			metric: 'update_cumulative_coverage',
			family: 'elementwise',
			description: 'Cumulative update mass spread.',
			lowMeans: 'concentrated',
			higherMeans: 'broader coverage',
		},
		{
			label: 'Matrix Rank Fraction',
			metric: 'update_rank_fraction',
			family: 'matrix',
			description: 'Many singular directions carry mass.',
			lowMeans: 'low-rank',
			higherMeans: 'broad spread',
		},
		{
			label: 'Orthogonality',
			metric: 'update_orthogonality_error',
			family: 'matrix',
			invert: true,
			description: 'Matrix updates stay balanced.',
			lowMeans: 'balanced',
			higherMeans: 'unbalanced',
		},
	];
	const metricGroups = [
		{
			title: 'Relative Update Geometry',
			metrics: {
				update_neg_grad_cos: {
					title: 'Gradient alignment',
					subtitle: 'mean cos(update, -grad)',
				},
					update_prev_update_cos: {
						title: 'Update consistency',
						subtitle: 'mean cos(update_t, update_t-1)',
					},
					update_neg_grad_ema_cos: {
						title: 'EMA gradient alignment',
						subtitle: 'mean cos(update, -grad EMA)',
					},
					update_theta_norm_ratio: {
						title: 'Update / weights',
					subtitle: 'mean ||update|| / ||theta||',
				},
			},
		},
		{
			title: 'Norms And Elementwise Geometry',
			metrics: {
				grad_norm: {
					title: 'Gradient norm',
					subtitle: 'mean ||grad||',
				},
				update_norm: {
					title: 'Update norm',
					subtitle: 'mean ||update||',
				},
				theta_norm: {
					title: 'Weight norm',
					subtitle: 'mean ||theta||',
				},
				update_effective_lr_log_std: {
					title: 'Effective LR spread',
					subtitle: 'std(log(abs(update / grad)))',
				},
				update_grad_rms_suppression_corr: {
					title: 'RMS suppression correlation',
					subtitle: 'corr(log grad RMS history, log effective LR)',
				},
				update_cumulative_coverage: {
					title: 'Cumulative coverage',
					subtitle: 'effective support of accumulated abs updates',
				},
			},
		},
		{
			title: 'Intrinsic Update Matrix Geometry',
			metrics: {
				update_rank_fraction: {
					title: 'Rank fraction',
					subtitle: 'stable-rank fraction of matrix updates',
				},
				update_orthogonality_error: {
					title: 'Orthogonality error',
					subtitle: 'mean scaled Gram deviation',
				},
			},
		},
	];
	const metricInfo = Object.assign({}, ...metricGroups.map((group) => group.metrics));
	const ratioMetrics = new Set(['grad_norm', 'update_norm', 'theta_norm', 'update_theta_norm_ratio']);
	const format = (value) => {
		if (!Number.isFinite(value)) return 'n/a';
		const abs = Math.abs(value);
		if (abs !== 0 && (abs < 0.01 || abs >= 10000)) return value.toExponential(2);
		return value.toLocaleString('en-US', { maximumFractionDigits: 6 });
	};
	const formatOverviewValue = (value) => {
		if (!Number.isFinite(value)) return 'n/a';
		const abs = Math.abs(value);
		if (abs !== 0 && abs < 0.01) return value < 0 ? '>-0.01' : '<0.01';
		if (abs >= 10000) return value.toExponential(2);
		return value.toLocaleString('en-US', { maximumFractionDigits: 2 });
	};
	const selectedFingerprint = () => fingerprints[Number(fingerprintSelect?.value ?? 0)]?.full;

	function render() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		ensureCustomSelection(fingerprint);
		renderMeta(fingerprint);
		renderOverview(fingerprint);
		renderCharts(fingerprint);
	}

	function renderMeta(fingerprint) {
		optimizerTrigger.textContent = fingerprint.optimizer.name;
		optimizerTrigger.setAttribute('aria-label', `Current run: ${fingerprint.optimizer.name}. Change run`);
		document.title = `${fingerprint.optimizer.name} - Trace`;
	}

	function renderOptimizerMenu() {
		optimizerMenu.replaceChildren(
			...fingerprints.map(({ full }, index) => {
				const option = document.createElement('button');
				option.type = 'button';
				option.className = 'optimizer-option';
				option.setAttribute('role', 'option');
				option.setAttribute('aria-selected', String(Number(fingerprintSelect?.value ?? 0) === index));
				option.textContent = full.optimizer.name;
				option.addEventListener('click', () => {
					fingerprintSelect.value = String(index);
					closeOptimizerMenu();
					customNames.clear();
					render();
				});
				return option;
			}),
		);
	}

	function openOptimizerMenu() {
		renderOptimizerMenu();
		optimizerMenu.setAttribute('aria-hidden', 'false');
		optimizerTrigger.setAttribute('aria-expanded', 'true');
	}

	function closeOptimizerMenu() {
		optimizerMenu.setAttribute('aria-hidden', 'true');
		optimizerTrigger.setAttribute('aria-expanded', 'false');
	}

	function toggleOptimizerMenu() {
		if (optimizerMenu.getAttribute('aria-hidden') === 'false') closeOptimizerMenu();
		else openOptimizerMenu();
	}

	function ensureCustomSelection(fingerprint) {
		if (customNames.size > 0) return;
		for (const name of depthProbeNames(fingerprint)) customNames.add(name);
	}

	function depthProbeNames(fingerprint) {
		const available = new Set(fingerprint.snapshots[0].parameters.map((parameter) => parameter.name));
		return ['embed.weight', 'blocks.0.attn.q.weight', 'blocks.0.attn.k.weight', 'blocks.0.attn.v.weight', 'blocks.0.mlp.c_fc.weight', 'proj.weight'].filter(
			(name) => available.has(name),
		);
	}

	function selectedParameters(fingerprint) {
		if (selectedParameterSet === 'custom') return fingerprint.snapshots[0].parameters.filter((parameter) => customNames.has(parameter.name));
		return parameterSetParameters(fingerprint, selectedParameterSet);
	}

	function parameterSetParameters(fingerprint, set) {
		const params = fingerprint.snapshots[0].parameters;
		if (set === 'all_parameters') return params;
		const predicates = {
			matrix_parameters: (parameter) => parameter.ndim >= 2,
			vector_parameters: (parameter) => parameter.ndim < 2,
			embeddings: (parameter) => parameter.name.includes('embed') || parameter.name.includes('wte') || parameter.name.includes('wpe'),
			attention: (parameter) => parameter.name.includes('.attn.'),
			attention_qkv: (parameter) => ['.attn.q.', '.attn.k.', '.attn.v.'].some((part) => parameter.name.includes(part)),
			attention_proj: (parameter) => parameter.name.includes('.attn.proj.') || parameter.name === 'proj.weight',
			mlp: (parameter) => parameter.name.includes('.mlp.') || parameter.name.includes('.ffn.'),
			norms: (parameter) => parameter.name.includes('norm') || parameter.name.includes('.ln'),
			output_head: (parameter) => parameter.name.includes('head') || parameter.name === 'proj.weight' || parameter.name.includes('lm_head'),
			optimizer_0: (parameter) => parameter.optimizer_index === 0,
			optimizer_1: (parameter) => parameter.optimizer_index === 1,
		};
		return params.filter(predicates[set] ?? (() => false));
	}

	function averagedSeries(fingerprint, metric) {
		const names = new Set(selectedParameters(fingerprint).map((parameter) => parameter.name));
		return fingerprint.snapshots.map((snapshot) => {
			const values = snapshot.parameters
				.filter((parameter) => names.has(parameter.name))
				.map((parameter) => parameter.metrics[metric])
				.filter((value) => Number.isFinite(value));
			const mean = values.length ? values.reduce((sum, value) => sum + value, 0) / values.length : null;
			const variance = values.length ? values.reduce((sum, value) => sum + (value - mean) ** 2, 0) / values.length : 0;
			const std = Math.sqrt(variance);
			return {
				step: snapshot.step,
				value: mean,
				low: values.length ? mean - std : null,
				high: values.length ? mean + std : null,
				count: values.length,
			};
		});
	}

	function overviewMetricsForFingerprint(fingerprint) {
		return new Map(
			overviewMetrics.map((spec) => {
				const raw = weightedSnapshotMean(fingerprint, spec.metric, overviewParameterSet);
				return [
					spec.metric,
					{
						raw,
						score: overviewScore(raw, spec),
					},
				];
			}),
		);
	}

	function weightedSnapshotMean(fingerprint, metric, parameterSet) {
		const selected = parameterSetParameters(fingerprint, parameterSet);
		const selectedNames = new Set(selected.map((parameter) => parameter.name));
		const parameterWeights = new Map(selected.map((parameter) => [parameter.name, parameter.numel]));
		const parameterValues = new Map();
		for (const snapshot of fingerprint.snapshots) {
			for (const parameter of snapshot.parameters) {
				if (!selectedNames.has(parameter.name)) continue;
				const value = parameter.metrics[metric];
				if (!Number.isFinite(value)) continue;
				const values = parameterValues.get(parameter.name) ?? [];
				values.push(value);
				parameterValues.set(parameter.name, values);
			}
		}
		let weightedSum = 0;
		let weightSum = 0;
		for (const [name, values] of parameterValues) {
			const weight = parameterWeights.get(name);
			if (!Number.isFinite(weight) || weight <= 0 || values.length === 0) continue;
			const mean = values.reduce((sum, value) => sum + value, 0) / values.length;
			weightedSum += mean * weight;
			weightSum += weight;
		}
		return weightSum > 0 ? weightedSum / weightSum : null;
	}

	function weightedSnapshotSeries(fingerprint, metric, parameterSet) {
		const selected = parameterSetParameters(fingerprint, parameterSet);
		const selectedNames = new Set(selected.map((parameter) => parameter.name));
		const parameterWeights = new Map(selected.map((parameter) => [parameter.name, parameter.numel]));
		return fingerprint.snapshots.map((snapshot) => {
			let weightedSum = 0;
			let weightSum = 0;
			for (const parameter of snapshot.parameters) {
				if (!selectedNames.has(parameter.name)) continue;
				const value = parameter.metrics[metric];
				const weight = parameterWeights.get(parameter.name);
				if (!Number.isFinite(value) || !Number.isFinite(weight) || weight <= 0) continue;
				weightedSum += value * weight;
				weightSum += weight;
			}
			return {
				step: snapshot.step,
				value: weightSum > 0 ? weightedSum / weightSum : null,
				count: weightSum > 0 ? selectedNames.size : 0,
			};
		});
	}

	function overviewScore(raw, spec) {
		if (!Number.isFinite(raw)) return null;
		let score = raw;
		if (spec.scale === 'log') {
			if (raw <= 0) return null;
			score = Math.log10(raw);
		}
		return spec.invert ? -score : score;
	}

	function overviewValuesForSet() {
		return new Map(fingerprints.map(({ full }) => [full.fingerprint_id, overviewMetricsForFingerprint(full)]));
	}

	function overviewPercentilesForSet(overviewValues) {
		return new Map(
			overviewMetrics.map((spec) => [
				spec.metric,
				percentilesForMetric(
					fingerprints.map(({ full }) => full),
					spec,
					overviewValues,
				),
			]),
		);
	}

	function percentilesForMetric(allFingerprints, spec, overviewValues) {
		const entries = allFingerprints
			.map((fingerprint) => {
				const value = overviewValues.get(fingerprint.fingerprint_id)?.get(spec.metric);
				return { id: fingerprint.fingerprint_id, score: value?.score };
			})
			.filter((entry) => Number.isFinite(entry.score))
			.sort((a, b) => a.score - b.score);
		const result = new Map();
		if (entries.length === 1) {
			result.set(entries[0].id, 100);
			return result;
		}
		for (let index = 0; index < entries.length; ) {
			let end = index + 1;
			while (end < entries.length && entries[end].score === entries[index].score) end += 1;
			const averageRank = (index + end - 1) / 2;
			const percentile = entries.length > 1 ? (averageRank / (entries.length - 1)) * 100 : 100;
			for (let tiedIndex = index; tiedIndex < end; tiedIndex += 1) {
				result.set(entries[tiedIndex].id, percentile);
			}
			index = end;
		}
		return result;
	}

	function renderOverview(fingerprint) {
		const card = root.querySelector('[data-overview-card]');
		const overviewValues = overviewValuesForSet();
		const overviewPercentiles = overviewPercentilesForSet(overviewValues);
		const values = overviewValues.get(fingerprint.fingerprint_id);
		const header = document.createElement('header');
		const titleWrap = document.createElement('div');
		const title = document.createElement('h2');
		title.textContent = 'Overview';
		const note = document.createElement('div');
		note.className = 'overview-note';
		note.textContent = 'Time-averaged per parameter, weighted by parameter count.';
		titleWrap.append(title, note);
		header.append(titleWrap, makeOverviewParameterSelector());

		const grid = document.createElement('div');
		grid.className = 'overview-grid';
		for (const spec of overviewMetrics) {
			const value = values?.get(spec.metric);
			const percentile = overviewPercentiles.get(spec.metric)?.get(fingerprint.fingerprint_id);
			const article = document.createElement('article');
			article.className = 'overview-metric';
			article.title = `${spec.metric}: higher means ${spec.higherMeans}`;
			const top = document.createElement('div');
			top.className = 'overview-metric-top';
			const label = document.createElement('div');
			label.className = 'overview-label';
			label.textContent = spec.label;
			const description = document.createElement('div');
			description.className = 'overview-description';
			description.textContent = spec.description;
			const direction = document.createElement('div');
			direction.className = 'overview-direction';
			direction.textContent = `Low = ${spec.lowMeans} / higher = ${spec.higherMeans}`;
			top.append(label, description, direction);
			const raw = document.createElement('div');
			raw.className = 'overview-value';
			raw.textContent = formatOverviewValue(value?.raw);
			const rank = document.createElement('div');
			rank.className = 'overview-percentile';
			const swatch = document.createElement('span');
			swatch.className = 'overview-swatch';
			if (Number.isFinite(percentile)) {
				swatch.style.setProperty('--percentile-color', percentileColor(percentile));
				swatch.style.setProperty('--percentile-width', `${Math.max(0, Math.min(100, percentile))}%`);
			}
			const text = document.createElement('span');
			text.className = 'overview-rank';
			text.textContent = Number.isFinite(percentile) ? `p${Math.round(percentile)}` : 'n/a';
			rank.append(swatch, text);
			article.append(top, raw, rank);
			grid.append(article);
		}
		card.replaceChildren(header, grid);
	}

	function percentileColor(percentile) {
		const hue = 8 + (Math.max(0, Math.min(100, percentile)) / 100) * 132;
		return `hsl(${hue} 58% 42%)`;
	}

	function makeOverviewParameterSelector() {
		const field = document.createElement('div');
		field.className = 'field';
		const label = document.createElement('label');
		label.className = 'sr-only';
		label.textContent = 'Overview parameter set';
		const select = document.createElement('select');
		select.dataset.overviewParameterSetSelect = '';
		for (const [value, text] of parameterSetOptions) {
			const option = document.createElement('option');
			option.value = value;
			option.textContent = text;
			select.append(option);
		}
		select.value = overviewParameterSet;
		select.addEventListener('change', () => {
			overviewParameterSet = select.value;
			const fingerprint = selectedFingerprint();
			if (fingerprint) renderOverview(fingerprint);
		});
		field.append(label, select);
		return field;
	}

	function ordinal(value) {
		const suffix = value % 100 >= 11 && value % 100 <= 13 ? 'th' : { 1: 'st', 2: 'nd', 3: 'rd' }[value % 10] || 'th';
		return `${value}${suffix}`;
	}

	function makeParameterSelector(fingerprint) {
		const bar = document.createElement('div');
		bar.className = 'selector-bar';
		const controls = document.createElement('div');
		controls.className = 'selector-controls';
		const field = document.createElement('div');
		field.className = 'field';
		const label = document.createElement('label');
		label.className = 'sr-only';
		label.textContent = 'Parameter set';
		const select = document.createElement('select');
		select.dataset.parameterSetSelect = '';
		for (const [value, text] of chartParameterSetOptions) {
			const option = document.createElement('option');
			option.value = value;
			option.textContent = text;
			select.append(option);
		}
		select.value = selectedParameterSet;
		select.addEventListener('change', () => {
			selectedParameterSet = select.value;
			if (selectedParameterSet === 'custom') openCustomModal();
			render();
		});
		field.append(label, select);
		const edit = document.createElement('button');
		edit.type = 'button';
		edit.textContent = 'Edit custom';
		edit.addEventListener('click', openCustomModal);
		const summary = document.createElement('div');
		summary.className = 'set-summary';
		const params = selectedParameters(fingerprint);
		summary.textContent = `Averaging ${params.length} parameter${params.length === 1 ? '' : 's'}.`;
		controls.append(field, edit, summary);
		bar.append(controls);
		return bar;
	}

	function renderCharts(fingerprint) {
		for (const chart of chartInstances.values()) chart.dispose();
		chartInstances.clear();
		const sections = [];
		for (const group of metricGroups) {
			const isInitiallyOpen = openMetricGroups.has(group.title);
			const section = document.createElement('section');
			section.className = `metric-section${isInitiallyOpen ? '' : ' is-collapsed'}`;
			const metricCount = Object.keys(group.metrics).length;
			const summary = document.createElement('div');
			summary.className = 'metric-summary';
			const summaryText = document.createElement('div');
			summaryText.className = 'metric-summary-text';
			const collapsedTitle = document.createElement('h3');
			collapsedTitle.className = 'selector-title';
			collapsedTitle.textContent = group.title;
			const count = document.createElement('div');
			count.className = 'metric-count';
			count.textContent = `${metricCount} metric${metricCount === 1 ? '' : 's'}`;
			summaryText.append(collapsedTitle, count);
			const toggle = document.createElement('button');
			toggle.type = 'button';
			toggle.textContent = isInitiallyOpen ? 'Hide' : 'Show';
			toggle.setAttribute('aria-expanded', String(isInitiallyOpen));
			summary.append(summaryText, toggle);
			const selectorBar = makeParameterSelector(fingerprint);
			const stack = document.createElement('div');
			stack.className = 'chart-stack';
			const groupChartSpecs = [];
			for (const metric of Object.keys(group.metrics)) {
				const article = document.createElement('article');
				article.className = 'chart-card';
				const header = document.createElement('header');
				const titleWrap = document.createElement('div');
				const title = document.createElement('h3');
				title.textContent = metricInfo[metric].title;
				const subtitle = document.createElement('div');
				subtitle.className = 'chart-subtitle';
				subtitle.textContent = `${metricInfo[metric].subtitle} · ${metric}`;
				titleWrap.append(title, subtitle);
				header.append(titleWrap);
				if (ratioMetrics.has(metric)) header.append(makeScaleToggle(metric));
				const host = document.createElement('div');
				host.className = 'main-chart';
				const chartRoot = document.createElement('div');
				host.append(chartRoot);
				const note = document.createElement('div');
				note.className = 'chart-note';
				article.append(header, host, note);
				stack.append(article);
				groupChartSpecs.push({ chartRoot, note, metric });
			}
			let rendered = false;
			const renderGroupCharts = () => {
				if (rendered) return;
				for (const spec of groupChartSpecs) {
					renderLineChart(spec.chartRoot, spec.note, averagedSeries(fingerprint, spec.metric), spec.metric);
				}
				rendered = true;
			};
			toggle.addEventListener('click', () => {
				const collapsed = section.classList.toggle('is-collapsed');
				const isOpen = !collapsed;
				toggle.textContent = isOpen ? 'Hide' : 'Show';
				toggle.setAttribute('aria-expanded', String(isOpen));
				if (isOpen) openMetricGroups.add(group.title);
				else openMetricGroups.delete(group.title);
				if (isOpen) renderGroupCharts();
			});
			section.append(summary, selectorBar, stack);
			sections.push(section);
			if (isInitiallyOpen) queueMicrotask(renderGroupCharts);
		}
		root.querySelector('[data-metric-sections]').replaceChildren(...sections);
	}

	function makeScaleToggle(metric) {
		const wrap = document.createElement('div');
		wrap.className = 'scale-toggle';
		for (const scale of ['log', 'linear']) {
			const button = document.createElement('button');
			button.type = 'button';
			button.textContent = scale;
			button.setAttribute('aria-pressed', String(ratioScales[metric] === scale));
			button.addEventListener('click', () => {
				ratioScales[metric] = scale;
				const fingerprint = selectedFingerprint();
				if (fingerprint) renderCharts(fingerprint);
			});
			wrap.append(button);
		}
		return wrap;
	}

	function renderLineChart(host, note, points, metric) {
		const cosineMetric = metric === 'update_neg_grad_cos' || metric === 'update_prev_update_cos';
		const logScale = ratioMetrics.has(metric) && ratioScales[metric] === 'log';
		const transformed = points
			.map((point) => ({
				step: point.step,
				rawValue: point.value,
				value: logScale && Number.isFinite(point.value) && point.value > 0 ? Math.log10(point.value) : point.value,
				low:
					logScale && Number.isFinite(point.low) && point.low > 0
						? Math.log10(point.low)
						: !logScale
							? point.low
							: null,
				high:
					logScale && Number.isFinite(point.high) && point.high > 0
						? Math.log10(point.high)
						: !logScale
							? point.high
							: null,
				count: point.count,
			}))
			.filter((point) => Number.isFinite(point.value) && (!logScale || point.rawValue > 0));
		const missing = points.filter((point) => !point.count).length;
		note.textContent = missing ? `${missing} snapshot${missing === 1 ? '' : 's'} had no finite values for this group and metric.` : '';
		const chart = echarts.init(host, null, { renderer: 'svg' });
		chartInstances.set(host, chart);
		const steps = transformed.map((point) => point.step);
		const xMin = steps.length ? Math.min(...steps) : 0;
		const xMax = steps.length ? Math.max(...steps) : 1;
		const xInterval = Math.max(Math.round((xMax - xMin) / 300) * 100, 100);
		const meanData = transformed.map((point) => [point.step, point.value, point.rawValue, point.count]);
		const bandPoints = transformed.filter((point) => Number.isFinite(point.low) && Number.isFinite(point.high));
		const bandValues = transformed.flatMap((point) => [point.low, point.high]).filter((value) => Number.isFinite(value));
		const dataMax = transformed.length ? Math.max(...transformed.map((point) => point.value), ...bandValues) : 1;
		const dataMin = transformed.length ? Math.min(...transformed.map((point) => point.value), ...bandValues) : 0;
		const yMin = cosineMetric ? -1.05 : logScale ? Math.floor(dataMin) : 0;
		const yMax = cosineMetric
			? 1.05
			: logScale
				? Math.max(Math.ceil(dataMax + 0.12), Math.floor(dataMin) + 1)
				: Math.max(dataMax * 1.18, dataMax + 1e-12);
		chart.setOption({
			animation: false,
			color: ['#7b2d26'],
			grid: { left: 54, right: 16, top: 24, bottom: 34 },
			tooltip: {
				trigger: 'axis',
				confine: true,
				axisPointer: { type: 'line', lineStyle: { color: '#bfb4a4' } },
				formatter: (items) => {
					const mean = items.find((item) => item.seriesName === 'mean');
					if (!mean) return '';
					const raw = mean.data?.[2] ?? mean.data?.[1];
					const count = mean.data?.[3];
					return `step ${mean.data[0]}<br/>mean: ${format(raw)}${count ? `<br/>n: ${count}` : ''}`;
				},
			},

			xAxis: {
				type: 'value',
				min: xMin,
				max: xMax,
				interval: xInterval,
				splitNumber: 2,
				axisLine: { show: false },
				axisTick: { show: false },
				axisLabel: {
					color: '#6f675c',
					fontFamily: 'IBM Plex Mono, monospace',
					hideOverlap: true,
					formatter: (value) =>
						value > 0 && value % xInterval === 0 ? String(Math.round(value)) : '',
				},
				splitLine: {
					show: true,
					lineStyle: { color: 'rgba(191, 180, 164, 0.35)', width: 1 },
				},
			},

			yAxis: {
				type: 'value',
				min: yMin,
				max: yMax,
				interval: cosineMetric ? 1 : undefined,
				splitNumber: 2,
				boundaryGap: false,

				axisLine: { show: false },
				axisTick: { show: false },
				axisLabel: {
					color: '#6f675c',
					fontFamily: 'IBM Plex Mono, monospace',
					hideOverlap: true,
					formatter: (value) => axisLabel(value, { logScale, cosineMetric }),
				},
				splitLine: {
					show: true,
					lineStyle: { color: 'rgba(191, 180, 164, 0.35)', width: 1 },
				},
			},

			series: [
				...(bandPoints.length > 1
					? [
							{
								name: 'mean ± std',
								type: 'custom',
								data: [0],
								renderItem: (_params, api) => {
									const upper = bandPoints.map((point) => api.coord([point.step, point.high]));
									const lower = [...bandPoints].reverse().map((point) => api.coord([point.step, point.low]));
									return {
										type: 'polygon',
										shape: { points: [...upper, ...lower] },
										style: { fill: '#7b2d26', opacity: 0.14 },
									};
								},
								silent: true,
								z: 1,
							},
						]
					: []),

				{
					name: 'mean',
					type: 'line',
					data: meanData,
					symbol: 'circle',
					symbolSize: 4,
					lineStyle: { color: '#7b2d26', width: 2 },
					itemStyle: { color: '#7b2d26' },
					z: 2,
				},
			],
		});
	}

	function axisLabel(value, { logScale, cosineMetric }) {
		if (cosineMetric) {
			for (const tick of [-1, 0, 1]) {
				if (Math.abs(value - tick) < 0.08) return formatSigFig(tick);
			}
			return '';
		}
		if (logScale) return formatSigFig(10 ** value);
		return formatSigFig(value);
	}

	function formatSigFig(value) {
		if (!Number.isFinite(value)) return 'n/a';
		if (value === 0) return '0';
		const abs = Math.abs(value);
		if (abs < 0.01 || abs >= 10000) return value.toExponential(1);
		return Number(value.toPrecision(2)).toString();
	}

	function openCustomModal() {
		selectedParameterSet = 'custom';
		renderCustomList();
		customModal.setAttribute('aria-hidden', 'false');
	}

	function closeCustomModal() {
		customModal.setAttribute('aria-hidden', 'true');
	}

	function visibleCustomParameters() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return [];
		const filter = String(customFilter?.value ?? '').trim().toLowerCase();
		return fingerprint.snapshots[0].parameters.filter((parameter) => !filter || parameter.name.toLowerCase().includes(filter));
	}

	function renderCustomList() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		const visible = visibleCustomParameters();
		customList.replaceChildren(
			...visible.map((parameter) => {
				const label = document.createElement('label');
				label.className = 'custom-option';
				const checkbox = document.createElement('input');
				checkbox.type = 'checkbox';
				checkbox.value = parameter.name;
				checkbox.checked = customNames.has(parameter.name);
				checkbox.addEventListener('change', () => {
					if (checkbox.checked) customNames.add(parameter.name);
					else customNames.delete(parameter.name);
					renderCustomCount();
				});
				const span = document.createElement('span');
				span.textContent = parameter.name;
				label.append(checkbox, span);
				return label;
			}),
		);
		renderCustomCount();
	}

	function renderCustomCount() {
		const fingerprint = selectedFingerprint();
		if (!fingerprint) return;
		root.querySelector('[data-custom-count]').textContent =
			`${customNames.size} selected / ${visibleCustomParameters().length} visible / ${fingerprint.snapshots[0].parameters.length} total`;
	}

	fingerprintSelect?.addEventListener('change', () => {
		customNames.clear();
		render();
	});
	optimizerTrigger?.addEventListener('click', toggleOptimizerMenu);
	document.addEventListener('click', (event) => {
		if (!root?.querySelector('.optimizer-picker')?.contains(event.target)) closeOptimizerMenu();
	});
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeOptimizerMenu();
	});
	customClose?.addEventListener('click', closeCustomModal);
	customModal?.addEventListener('click', (event) => {
		if (event.target === customModal) closeCustomModal();
	});
	customFilter?.addEventListener('input', renderCustomList);
	customSelectVisible?.addEventListener('click', () => {
		for (const parameter of visibleCustomParameters()) customNames.add(parameter.name);
		renderCustomList();
	});
	customClear?.addEventListener('click', () => {
		customNames.clear();
		renderCustomList();
	});
	customApply?.addEventListener('click', () => {
		closeCustomModal();
		render();
	});
	window.addEventListener('resize', () => {
		for (const chart of chartInstances.values()) chart.resize();
	});
	render();
</script>
